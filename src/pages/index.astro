---
import { readFile } from "node:fs/promises";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import profile from "../data/profile.json";
import "../styles/global.css";

const { name, title, summary, email, github, about, skills, experience, projects } = profile;
const base = import.meta.env.BASE_URL;
const siteRootDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "../..");
const siblingRootDir = path.resolve(siteRootDir, "..");
const markdownProcessor = await createMarkdownProcessor();

const inferRepoDir = (project) => {
  if (typeof project.localRepoDir === "string" && project.localRepoDir.trim()) {
    return project.localRepoDir.trim();
  }

  if (typeof project.repo !== "string" || !project.repo.trim()) {
    return null;
  }

  try {
    const repoUrl = new URL(project.repo);
    const segments = repoUrl.pathname.split("/").filter(Boolean);
    return segments.at(-1) ?? null;
  } catch {
    const trimmed = project.repo.trim().replace(/\/+$/, "");
    const parts = trimmed.split("/").filter(Boolean);
    return parts.at(-1) ?? null;
  }
};

const splitDeckPages = (markdown) => {
  const pages = [];
  let buffer = [];

  for (const line of markdown.split(/\r?\n/)) {
    if (line.trim() === "---") {
      const page = buffer.join("\n").trim();
      if (page) {
        pages.push(page);
      }
      buffer = [];
      continue;
    }
    buffer.push(line);
  }

  const tail = buffer.join("\n").trim();
  if (tail) {
    pages.push(tail);
  }

  return pages;
};

const projectsWithSlides = await Promise.all(
  (projects ?? []).map(async (project) => {
    const repoDir = inferRepoDir(project);

    if (!repoDir) {
      return {
        ...project,
        slideData: {
          pages: [],
          error: "Slides unavailable: local repo directory is not configured.",
        },
      };
    }

    const deckPath = path.join(siblingRootDir, repoDir, "interview_presentation", "deck.md");

    try {
      const markdown = await readFile(deckPath, "utf8");
      const parsedPages = splitDeckPages(markdown);
      if (!parsedPages.length) {
        return {
          ...project,
          localRepoDir: repoDir,
          slideData: {
            pages: [],
            error: "No slides found.",
          },
        };
      }

      const pages = await Promise.all(
        parsedPages.map(async (pageContent) => {
          const rendered = await markdownProcessor.render(pageContent, { fileURL: deckPath });
          return {
            html: rendered.code,
          };
        }),
      );

      return {
        ...project,
        localRepoDir: repoDir,
        slideData: {
          pages,
        },
      };
    } catch {
      return {
        ...project,
        localRepoDir: repoDir,
        slideData: {
          pages: [],
          error: `Slides unavailable. Expected ${repoDir}/interview_presentation/deck.md.`,
        },
      };
    }
  }),
);

const ORDER = [
  "grpo-chess-model",
  "llm-gatekeeping",
  "llm-trajectories",
  "agent-oauth",
  "echo-forward",
];

const orderedProjectsWithSlides = ORDER.map((projectId) =>
  projectsWithSlides.find((project) => project.title === projectId),
).filter(Boolean);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name} — {title}</title>
    <meta name="description" content={summary} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="nav">
      <div class="container nav__inner">
        <a class="nav__mark" href="#top">{name}</a>
        <nav class="nav__links" aria-label="Primary">
          <a class="nav__link" href="#projects">Projects</a>
          <a class="nav__link" href="#experience">Proof</a>
          <a class="nav__link" href="#contact">Contact</a>
          <a class="nav__iconlink" href={github} target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="page">
      <section class="hero section" id="top">
        <div class="container">
          <p class="hero__subtitle">{title}</p>
          <h1 class="hero__title">{name}</h1>
          <p class="hero__summary">{summary}</p>
          <div class="hero__ctas">
            <a class="btn btn--primary" href="#projects">View projects</a>
            <a class="btn btn--ghost" href={github} target="_blank" rel="noreferrer">GitHub</a>
          </div>
          <div class="chips" aria-label="Proof highlights">
            <span class="chip">5+ years end-to-end ML</span>
            <span class="chip">Led a 6-person ML team</span>
            <span class="chip">Shipped models into production</span>
          </div>
        </div>
      </section>

      <section class="focus section" id="focus">
        <div class="container">
          <div class="surface">
            <p class="eyebrow">Focus</p>
            <h2 class="section-title">{title}</h2>
            <p class="section-copy">{about}</p>
            <ul class="tag-row tag-row--skills" aria-label="Core skills">
              {skills?.map((skill) => (
                <li class="tag">{skill}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="projects section" id="projects">
        <div class="container">
          <div class="projects-intro">
            <p class="eyebrow">Projects</p>
            <h2 class="section-title">Research That Ships</h2>
            <p class="section-copy">
              Applied research projects built with production impact in mind, from evaluation design
              to robust real-world performance.
            </p>
          </div>

          <div class="projects-grid">
            {orderedProjectsWithSlides.map((project) => (
              <article class="project-card" id={`project-${project.title}`} data-project-card>
                <div class="project-card__static">
                  <div class="project-card__header">
                    <p class="eyebrow">Project</p>
                    <h3 class="project-card__title">{project.title}</h3>
                  </div>

                  <p class="project-card__problem">{project.summary}</p>

                  <ul class="tag-row">
                    {project.tags?.map((tag) => (
                      <li class="tag">{tag}</li>
                    ))}
                  </ul>

                  <div class="project-card__links">
                    {project.playUrl ? (
                      <a class="link link--primary" href={project.playUrl} target="_blank" rel="noreferrer">
                        Play the model
                      </a>
                    ) : (
                      <span class="link link--disabled">Play the model coming soon</span>
                    )}
                    {project.repo ? (
                      <a class="link" href={project.repo} target="_blank" rel="noreferrer">
                        View repo
                      </a>
                    ) : null}
                  </div>
                </div>

                <div class="project-card__live">
                  <div class="project-live__header">
                    <div>
                      <p class="project-live__kicker">Latest update</p>
                      <p class="project-live__hint">Live deck pulled from the project repo.</p>
                    </div>
                    <div class="project-live__actions">
                      <button class="deck-toggle" type="button" aria-expanded="false" data-deck-toggle>
                        Open full deck
                      </button>
                      <button class="deck-first" type="button" data-deck-first>
                        First slide
                      </button>
                      <button class="deck-fullscreen" type="button" data-deck-fullscreen>
                        Fullscreen
                      </button>
                    </div>
                  </div>

                  <div class="deck-teaser">
                    <ul>
                      <li>Active work: see deck</li>
                      <li>Recent changes and benchmarks</li>
                      <li>Next steps</li>
                    </ul>
                  </div>

                  <div class="deck-panel" hidden data-deck-panel>
                    <div class="deck-viewer" data-deck-viewer>
                      <div class="slide-viewer">
                      <div class="slide-header">
                        <div class="eyebrow">Interview slides</div>
                        {project.slideData.pages.length ? (
                          <span class="slide-count" data-page-indicator>
                            1/{project.slideData.pages.length}
                          </span>
                        ) : null}
                      </div>

                      {project.slideData.error ? (
                        <p class="slide-fallback">{project.slideData.error}</p>
                      ) : (
                        <>
                          <div class="slide-pages" data-slides>
                            {project.slideData.pages.map((page, pageIndex) => (
                              <article
                                class:list={["slide-page", pageIndex === 0 && "is-active"]}
                                data-slide-page
                                hidden={pageIndex !== 0}
                              >
                                <div class="slide-markdown" set:html={page.html} />
                              </article>
                            ))}
                          </div>
                          <div class="slide-controls" data-controls>
                            <button class="slide-btn" type="button" data-slide-prev disabled>
                              Prev
                            </button>
                            <button
                              class="slide-btn"
                              type="button"
                              data-slide-next
                              disabled={project.slideData.pages.length <= 1}
                            >
                              Next
                            </button>
                          </div>
                        </>
                      )}
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="about section" id="about">
        <div class="container">
          <div class="surface">
            <p class="eyebrow">About</p>
            <h2 class="section-title">Practical ML from research to production</h2>
            <p class="section-copy about__copy">{about}</p>
          </div>
        </div>
      </section>

      <section class="experience section" id="experience">
        <div class="container">
          <div class="surface">
            <p class="eyebrow">Proof</p>
            <h2 class="section-title">Built for real-world ML delivery</h2>
            <div class="proof-list">
              {experience?.map((role) => (
                <article class="proof-item">
                  <p class="proof-item__meta">
                    {role.role} · {role.company} · {role.period}
                  </p>
                  <ul class="proof-item__highlights">
                    {role.highlights?.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="contact section" id="contact">
        <div class="container">
          <div class="surface contact-card">
            <p class="eyebrow">Contact</p>
            <h2 class="section-title">Let’s talk</h2>
            <p class="section-copy">If you want to collaborate, hire, or discuss alignment work, reach out.</p>
            <div class="hero__ctas">
              <a class="btn btn--primary" href={`mailto:${email}`}>Email {name}</a>
              <a class="btn btn--ghost" href={github} target="_blank" rel="noreferrer">GitHub profile</a>
            </div>
          </div>
        </div>
      </section>

      <footer class="footer">
        <div class="container">Built with Astro · {new Date().getFullYear()}</div>
      </footer>

      <div class="deck-overlay" hidden data-deck-overlay>
        <div class="deck-overlay__backdrop" data-deck-overlay-close></div>
        <div class="deck-overlay__dialog" role="dialog" aria-modal="true" aria-label="Project deck fullscreen">
          <div class="deck-overlay__bar">
            <div class="deck-overlay__title" data-deck-overlay-title>Latest update</div>
            <button class="deck-overlay__close" type="button" data-deck-overlay-close>Close</button>
          </div>
          <div class="deck-overlay__content" data-deck-overlay-content></div>
        </div>
      </div>
    </main>

    <script is:inline>
      (() => {
        const projectCards = document.querySelectorAll("[data-project-card]");
        const overlay = document.querySelector("[data-deck-overlay]");
        const overlayContent = document.querySelector("[data-deck-overlay-content]");
        const overlayTitle = document.querySelector("[data-deck-overlay-title]");
        const overlayCloseButtons = document.querySelectorAll("[data-deck-overlay-close]");
        let activeFullscreen = null;

        const closeFullscreen = () => {
          if (!(overlay instanceof HTMLElement) || !(overlayContent instanceof HTMLElement)) {
            return;
          }

          if (activeFullscreen?.viewer instanceof HTMLElement && activeFullscreen.panel instanceof HTMLElement) {
            activeFullscreen.panel.append(activeFullscreen.viewer);
          }

          overlay.hidden = true;
          overlayContent.innerHTML = "";
          document.body.style.overflow = "";
          activeFullscreen = null;
        };

        overlayCloseButtons.forEach((button) => {
          button.addEventListener("click", () => {
            closeFullscreen();
          });
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeFullscreen();
          }
        });

        projectCards.forEach((card) => {
          const deckToggle = card.querySelector("[data-deck-toggle]");
          const deckPanel = card.querySelector("[data-deck-panel]");
          const firstButton = card.querySelector("[data-deck-first]");
          const fullscreenButton = card.querySelector("[data-deck-fullscreen]");
          const deckViewer = card.querySelector("[data-deck-viewer]");

          const goToFirst = () => {
            const prevButton = card.querySelector("[data-slide-prev]");
            const pageIndicator = card.querySelector("[data-page-indicator]");

            if (!(prevButton instanceof HTMLButtonElement)) {
              return;
            }

            const isCounterAtFirst = () => {
              if (!(pageIndicator instanceof HTMLElement)) {
                return false;
              }
              const counterText = pageIndicator.textContent?.trim() ?? "";
              return /^1\s*\/\s*\d+/.test(counterText);
            };

            let guard = 0;
            while (!prevButton.disabled && guard < 50) {
              if (isCounterAtFirst()) {
                break;
              }
              prevButton.click();
              guard += 1;
            }
          };

          const ensureOpen = () => {
            if (!(deckToggle instanceof HTMLButtonElement) || !(deckPanel instanceof HTMLElement)) {
              return false;
            }

            if (deckPanel.hidden) {
              deckToggle.setAttribute("aria-expanded", "true");
              deckToggle.textContent = "Collapse";
              deckPanel.hidden = false;
            }
            return true;
          };

          if (deckToggle instanceof HTMLButtonElement && deckPanel instanceof HTMLElement) {
            deckToggle.addEventListener("click", () => {
              const isExpanded = deckToggle.getAttribute("aria-expanded") === "true";
              const nextExpanded = !isExpanded;

              deckToggle.setAttribute("aria-expanded", String(nextExpanded));
              deckToggle.textContent = nextExpanded ? "Collapse" : "Open full deck";
              deckPanel.hidden = !nextExpanded;

              if (nextExpanded) {
                goToFirst();
              }
            });
          }

          if (firstButton instanceof HTMLButtonElement) {
            firstButton.addEventListener("click", () => {
              if (ensureOpen()) {
                goToFirst();
              }
            });
          }

          if (fullscreenButton instanceof HTMLButtonElement) {
            fullscreenButton.addEventListener("click", () => {
              if (
                !(overlay instanceof HTMLElement) ||
                !(overlayContent instanceof HTMLElement) ||
                !(overlayTitle instanceof HTMLElement) ||
                !(deckPanel instanceof HTMLElement) ||
                !(deckViewer instanceof HTMLElement)
              ) {
                return;
              }

              if (activeFullscreen) {
                closeFullscreen();
              }

              if (!ensureOpen()) {
                return;
              }

              goToFirst();

              const projectTitle = card.querySelector(".project-card__title");
              overlayTitle.textContent = projectTitle?.textContent?.trim()
                ? `${projectTitle.textContent.trim()} · Latest update`
                : "Latest update";

              overlayContent.append(deckViewer);
              overlay.hidden = false;
              document.body.style.overflow = "hidden";
              activeFullscreen = {
                viewer: deckViewer,
                panel: deckPanel,
              };
            });
          }

          const pages = Array.from(card.querySelectorAll("[data-slide-page]"));
          if (!pages.length) {
            return;
          }

          const prevButton = card.querySelector("[data-slide-prev]");
          const nextButton = card.querySelector("[data-slide-next]");
          const pageIndicator = card.querySelector("[data-page-indicator]");
          let currentPage = 0;

          const render = () => {
            pages.forEach((page, pageIndex) => {
              const isActive = pageIndex === currentPage;
              page.hidden = !isActive;
              page.classList.toggle("is-active", isActive);
            });

            if (pageIndicator) {
              pageIndicator.textContent = `${currentPage + 1}/${pages.length}`;
            }

            if (prevButton instanceof HTMLButtonElement) {
              prevButton.disabled = currentPage === 0;
            }
            if (nextButton instanceof HTMLButtonElement) {
              nextButton.disabled = currentPage === pages.length - 1;
            }
          };

          prevButton?.addEventListener("click", () => {
            if (currentPage === 0) {
              return;
            }
            currentPage -= 1;
            render();
          });

          nextButton?.addEventListener("click", () => {
            if (currentPage >= pages.length - 1) {
              return;
            }
            currentPage += 1;
            render();
          });

          render();
        });
      })();
    </script>
  </body>
</html>
